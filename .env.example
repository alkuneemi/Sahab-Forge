# Leave unset to use the same-origin "/odoo-proxy" path (default: works with
# the Vite dev proxy in vite.config.ts, or server/odoo-proxy.mjs reverse-
# proxied at that path in production).
#
# Set to "direct" to call each Odoo server's /jsonrpc straight from the
# browser instead (only works if that server already sends CORS headers
# for this app's origin).
#
# Set to an absolute URL if you deploy server/odoo-proxy.mjs on its own
# domain instead of reverse-proxying it under this app, e.g.:
# VITE_ODOO_PROXY_URL=https://proxy.example.com/odoo-proxy
VITE_ODOO_PROXY_URL=
